{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "polaris",
  "version": "10.1.4",
  "identifier": "com.polaris.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Polaris",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "hiddenTitle": true,
        "devtools": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": [
      "../dist"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGOUIyRUY5MDdBQ0JBNjYKUldSbXVxd0grUzZidjc5OUE5VU5QY0NCNGxCSDd0eVE2U0oyWlF2QWF2bDlGc2FJeFNxNHJXaXAK",
      "endpoints": [
        "https://github.com/misxzaiz/Polaris/releases/latest/download/latest.json"
      ]
    }
  }
}
