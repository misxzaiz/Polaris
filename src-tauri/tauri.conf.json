{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "polaris",
  "version": "9.9.2",
  "identifier": "com.polaris.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Polaris",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "hiddenTitle": true,
        "devtools": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../dist",
      "target/release/polaris-todo-mcp",
      "target/release/polaris-requirements-mcp",
      "target/release/polaris-scheduler-mcp",
      "target/release/polaris-computer-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2NjU5Mjk3QzM2NDQ0OUIKUldTYlJHVERsNUpsOXNyVyttM21DYVRKK2oxZnREV25MZVVxbkhkdWxGd0Z2VTQxUTZOdjhBZC8K",
      "endpoints": [
        "https://github.com/misxzaiz/Polaris/releases/latest/download/latest.json"
      ]
    }
  }
}
