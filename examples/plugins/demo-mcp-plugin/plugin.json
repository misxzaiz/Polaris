{
  "id": "example.demo-mcp",
  "name": "Demo MCP Plugin",
  "version": "0.1.0",
  "description": "A demo external MCP plugin for Polaris install and discovery testing.",
  "enabledByDefault": true,
  "origin": {
    "repository": "examples/plugins/demo-mcp-plugin",
    "homepage": "docs/mcp/5-demo-plugin.md"
  },
  "contributes": {
    "views": [
      {
        "id": "example.demo-mcp.panel",
        "area": "activityBar",
        "panelType": "demoPlugin",
        "icon": "Bot",
        "labelKey": "plugins.demoMcpPanel",
        "labelDefault": "Demo MCP",
        "order": 85
      }
    ],
    "mcpServers": [
      {
        "id": "example-demo-mcp",
        "transport": "stdio",
        "command": "node",
        "argsTemplate": [
          "{{pluginDir}}/mcp/demo-mcp-server.js",
          "{{workspacePath}}",
          "--polaris-port={{polarisPort}}",
          "--polaris-token={{polarisToken}}",
          "--polaris-session={{sessionId}}"
        ]
      }
    ],
    "chatCards": [
      {
        "id": "demo-confirm-card",
        "entry": "cards/demo-confirm-card.js",
        "mcpServerId": "example-demo-mcp",
        "tools": ["demo_confirm"],
        "mode": "interaction"
      }
    ]
  },
  "permissions": {
    "workspaceRead": true,
    "aiToolAccess": true
  }
}
