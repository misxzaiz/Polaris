#!/bin/bash
# pre-commit — 3D World Git 提交门禁
#
# 职责: 提交前自动运行质量检查，阻断不合格代码
# 检查: qa-gate.js 质量门禁
#
# 安装: 本文件会被放置到 .git/hooks/pre-commit（由 setup-hooks.sh 完成）

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
TOOLS_DIR="$PROJECT_ROOT/tools"

# 检测 git hooks 路径是否在 repo 根 .git/hooks
# 若 pre-commit 在 PROJECT_ROOT/.git/hooks，则 TOOLS_DIR 为 PROJECT_ROOT/tools
if [ ! -f "$TOOLS_DIR/qa-gate.js" ]; then
  # 回退: 查找 qa-gate.js
  QA_GATE=$(find "$PROJECT_ROOT" -name "qa-gate.js" -path "*/tools/*" | head -n1)
  if [ -z "$QA_GATE" ]; then
    echo "[pre-commit] 警告: 未找到 qa-gate.js，跳过检查"
    exit 0
  fi
  TOOLS_DIR=$(dirname "$QA_GATE")
fi

# 检查是否有暂存变更
if git diff --cached --quiet; then
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " 🚀 3D World · 提交质量门禁"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

node "$TOOLS_DIR/qa-gate.js" --ci

RESULT=$?
if [ $RESULT -ne 0 ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo " ❌ 质量门禁未通过！请修复上述问题后重试。"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  exit 1
fi

echo ""
echo " ✅ 质量门禁通过，提交继续..."
echo ""
exit 0
